{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", ".prettierrc.mjs"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/data/*": ["./src/data/*"],
      "@/images/*": ["./src/images/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/pages/*": ["./src/pages/*"],
      "@/sections/*": ["./src/sections/*"],
      "@/styles/*": ["./src/styles/*"]
    }
  }
}
