---
import Layout from "@/layouts/layout.astro";
import { monthsToShow } from "@/lib/events-logic.ts";
import eventsHeader from "@/images/monthly-events/events-header.jpg";
import { getImage } from "astro:assets";
import EventCard from "@/components/event-card.astro";
import TriviaCard from "@/components/trivia-card.astro";

const headerImage = await getImage({
  src: eventsHeader,
  format: "avif",
  quality: 70,
});
---

<Layout isTransparent={false}>
  <section
    id="events-hero"
    class="relative flex min-h-[80vh] items-center justify-center bg-cover bg-top bg-no-repeat bg-origin-content"
    style={`background-image: url(${headerImage.src});`}
  >
    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/75 via-black/10 to-transparent"
    >
    </div>
    <div class="flex flex-col items-center gap-2">
      <h2
        class="font-display text-base-100 bg-primary relative z-10 p-2 px-4 text-4xl font-bold tracking-wide uppercase"
      >
        Upcoming Events
      </h2>
    </div>
  </section>

  <section id="upcoming-events" class="bg-base-200 pt-6">
    <div class="container mx-auto px-4 pb-12 xl:max-w-6xl">
      <h2
        class="text-base-content mb-6 text-xl font-semibold uppercase md:text-3xl"
      >
        Upcoming Events
      </h2>

      <div class="flex flex-col items-start justify-between gap-6 lg:flex-row">
        <div class="order-2 lg:order-1 lg:flex-none">
          {
            monthsToShow.map((month) => (
              <>
                {month.events.map((event) => (
                  <EventCard event={event} month={month.monthName} />
                ))}
              </>
            ))
          }
        </div>
        <TriviaCard />
      </div>
    </div>
  </section>
</Layout>
