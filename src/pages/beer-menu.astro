---
import BeerFilterPanel from "@/components/beer-filter-panel.astro";
import BeerTabContent from "@/components/beer-tab-content.astro";
import MenuTab from "@/components/menu-tab.astro";
import beerItems from "@/data/beer-items.json";
import Layout from "@/layouts/layout.astro";
---

<Layout isTransparent={false}>
  <section id="beer-menu" class="bg-base-200 min-h-[80vh]">
    <div class="container mx-auto px-4 pt-28 pb-12 xl:max-w-6xl">
      <h2
        class="text-base-content mb-2 text-xl font-semibold uppercase md:text-3xl"
      >
        Beer Menu
      </h2>
      <div class="menu-tabs">
        <div class="tabs tabs-box flex-nowrap overflow-x-auto">
          {
            beerItems.map((beerItem) => (
              <MenuTab tabId={beerItem.category} checkedTab="hoppy" />
            ))
          }
        </div>
        <BeerFilterPanel />
        <div
          class="flex flex-col items-start justify-between gap-4 md:flex-row"
        >
          {
            beerItems.map((beerItem) => (
              <BeerTabContent
                tabId={beerItem.category}
                items={beerItem.items}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
