---
import Faqs from "@/sections/faqs.astro";
import Hours from "@/components/hours.astro";
import Location from "@/components/location.astro";
import contactHeader from "@/images/contact/contact-header.jpg";
import Layout from "@/layouts/layout.astro";
import { getImage } from "astro:assets";

const headerImage = await getImage({
  src: contactHeader,
  format: "avif",
  quality: 70,
});
---

<Layout title="Contact Us">
  <section
    id="contact-hero"
    class="relative flex min-h-[80vh] items-center justify-center bg-cover bg-top bg-no-repeat bg-origin-content"
    style={`background-image: url(${headerImage.src});`}
  >
    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/75 via-black/10 to-transparent"
    >
    </div>
    <div class="flex flex-col items-center gap-2">
      <h1
        class="font-display text-base-100 bg-primary relative z-10 p-2 px-4 text-4xl font-bold tracking-wide uppercase"
      >
        Contact Us
      </h1>
    </div>
  </section>

  <section id="contact" class="bg-base-200 pt-6">
    <div class="container mx-auto px-4 pb-12 xl:max-w-6xl">
      <p
        class="text-base-content mb-6 text-xl font-semibold uppercase md:text-3xl"
      >
        Contact Us
      </p>
      <div
        class="mb-10 flex flex-col items-start justify-between gap-4 md:flex-row"
      >
        <Location />
        <Hours />
      </div>
      <Faqs />
    </div>
  </section>
</Layout>
