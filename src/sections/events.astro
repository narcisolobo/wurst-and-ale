---
import featuredEvents from "@/data/featured-events.json";
import FeaturedEventCard from "@/components/featured-event-card.astro";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/event-images/*.jpg",
);
---

<section id="featured-events">
  <div class="container mx-auto max-w-6xl px-4 py-12">
    <h2
      class="text-base-content mb-2 text-xl font-semibold uppercase md:text-3xl"
    >
      Featured Events
    </h2>
    {
      featuredEvents.map(async (event, i) => {
        const imagePath = `/src/images/event-images/${event.image}`;
        const imageModule = images[imagePath];
        const image = (await imageModule()).default;
        return <FeaturedEventCard image={image} event={event} i={i} />;
      })
    }
  </div>
</section>
