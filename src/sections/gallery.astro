---
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/images/event-images/*.jpg",
);
---

<section id="gallery" class="bg-base-200 min-h-[80vh]">
  <div class="container mx-auto px-4 py-12 xl:max-w-6xl">
    <h2
      class="text-base-content mb-2 text-xl font-semibold uppercase md:text-3xl"
    >
      Gallery
    </h2>
  </div>
</section>
