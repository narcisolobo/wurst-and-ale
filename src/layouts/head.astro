---
import { buildStructuredData } from "@/lib/structured-data";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ogImageUrl = new URL("/og-image.jpg", Astro.site).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = buildStructuredData({
  description,
  ogImageUrl,
  site: Astro.site,
});
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="description" content={description} />
  <meta name="author" content="Narciso Lobo" />

  <!-- icons -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/wurst-ale-favicon.svg" />
  <link rel="shortcut icon" href="/wurst-ale-favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Wurst & Ale" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph (social previews: Slack, Twitter/X, LinkedIn, etc.) -->
  <meta property="og:title" content="Wurst & Ale Demo Site" />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Wurst & Ale Demo" />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <title>{title} | Wurst and Ale</title>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(structuredData)}
  />
</head>
