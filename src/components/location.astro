---
import Facebook from "@/icons/facebook.astro";
import Instagram from "@/icons/instagram.astro";
---

<div id="location" class="flex-1">
  <div class="card bg-base-100 w-auto rounded-none shadow-sm">
    <div class="card-body">
      <h3 class="mb-2 text-4xl font-semibold uppercase">Wurst & Ale</h3>
      <address class="mb-4 text-lg not-italic">
        3401 N. Southport Ave.,<br />
        Chicago, IL 60657<br />
        <a
          target="_blank"
          class="text-xs uppercase"
          href="https://maps.app.goo.gl/cs8nN1D5bS9VLLXu5"
        >
          Get directions
        </a><br /><br />
        TEL: <a href="tel:+17735551234">(773) 555-1234</a><br />
        EMAIL: <a href="mailto:wurstale@example.com">wurstale@example.com</a>
      </address>
      <p class="text-lg">Follow us on social media:</p>
      <div class="mb-4 flex items-center gap-2">
        <button class="btn btn-circle">
          <Facebook />
        </button>
        <button class="btn btn-circle">
          <Instagram />
        </button>
      </div>
      <div class="relative aspect-4/3 w-full overflow-hidden">
        <iframe
          title="Google Map"
          src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2967.6327044649092!2d-87.66618562391207!3d41.943743271234666!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDHCsDU2JzM3LjUiTiA4N8KwMzknNDkuMCJX!5e0!3m2!1sen!2sus!4v1783899298828!5m2!1sen!2sus"
          class="absolute inset-0 h-full w-full"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
    </div>
  </div>
</div>
