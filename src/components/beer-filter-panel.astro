<div class="bg-base-100 mt-4 flex gap-4 rounded-md p-2 text-sm shadow">
  <span class="font-semibold">Filter by origin:</span>
  <label class="flex cursor-pointer items-center gap-2">
    <input type="checkbox" id="origin-domestic" class="checkbox checkbox-xs" />
    Domestic
  </label>
  <label class="flex cursor-pointer items-center gap-2">
    <input type="checkbox" id="origin-craft" class="checkbox checkbox-xs" />
    Craft & Local
  </label>
  <label class="flex cursor-pointer items-center gap-2">
    <input type="checkbox" id="origin-import" class="checkbox checkbox-xs" />
    Import
  </label>
</div>

<style is:global>
  [data-beer-item] {
    display: none;
  }
  .menu-tabs:not(:has(#origin-domestic:checked)):not(
      :has(#origin-craft:checked)
    ):not(:has(#origin-import:checked))
    [data-beer-item] {
    display: table-row;
  }
  .menu-tabs:has(#origin-domestic:checked)
    [data-beer-item][data-origin="domestic"] {
    display: table-row;
  }
  .menu-tabs:has(#origin-craft:checked) [data-beer-item][data-origin="craft"] {
    display: table-row;
  }
  .menu-tabs:has(#origin-import:checked)
    [data-beer-item][data-origin="import"] {
    display: table-row;
  }
</style>
