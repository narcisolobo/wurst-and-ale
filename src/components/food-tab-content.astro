---
import Spicy from "@/icons/spicy.astro";
import Popular from "@/icons/popular.astro";
import Vegan from "@/icons/vegan.astro";

interface MenuItem {
  id: string;
  title: string;
  description: string;
  price: number;
  subcategory?: string;
  isVegan: boolean;
  isSpicy: boolean;
  isPopular: boolean;
}

interface Props {
  tabId: string;
  items: MenuItem[];
}

const { tabId, items } = Astro.props;

/* Group items by subcategory. Items with no subcategory all collapse
into a single group under the `null` key, which is rendered without
a heading — this lets burgers (no subcategories) and links (three
subcategories) share the exact same rendering logic below. */
const groups = items.reduce((acc, item) => {
  const key = item.subcategory ?? null;
  if (!acc.has(key)) acc.set(key, []);
  acc.get(key)!.push(item);
  return acc;
}, new Map<string | null, MenuItem[]>());
---

<div class="tab-panel mt-4 hidden" data-tab-panel={tabId}>
  <div class="bg-base-100 rounded-lg p-6 shadow">
    {
      [...groups.entries()].map(([subcategory, groupItems]) => (
        <div class="mb-8 last:mb-0">
          {subcategory && (
            <h3 class="mb-2 text-lg font-semibold uppercase">{subcategory}</h3>
          )}
          <table class="table-zebra table">
            <tbody>
              {groupItems.map((item) => (
                <tr>
                  <td>
                    <div class="flex">
                      {item.isSpicy && <Spicy classes={["mr-1"]} />}
                      {item.isPopular && <Popular classes={["mr-1"]} />}
                      {item.isVegan && <Vegan classes={["mr-1"]} />}
                      <p class="font-semibold">{item.title} </p>
                    </div>
                    <p>{item.description}</p>
                  </td>
                  <td class="text-right align-top md:align-middle">
                    ${item.price.toFixed(2)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))
    }
  </div>

  <style
    set:html={`
.menu-tabs:has(#${tabId}:checked) [data-tab-panel="${tabId}"] {
  display: block;
}`}
  ></style>
</div>
