---
interface Props {
  tabId: string;
  checkedTab: string;
}

const { tabId, checkedTab } = Astro.props;

const capitalizeFirstLetter = (str: string) => {
  if (!str) return "";
  return str.charAt(0).toUpperCase() + str.slice(1);
};
---

<label class="tab shrink-0">
  <input
    type="radio"
    name="menu-tabs"
    id={tabId}
    class="hidden"
    checked={tabId === checkedTab}
  />
  {capitalizeFirstLetter(tabId)}
</label>
