---
interface Props {
  tabIds: string[];
}

const { tabIds } = Astro.props;
const panelId = tabIds.join("-");

const rules = tabIds
  .map(
    (id) =>
      `.menu-tabs:has(#${id}:checked) [data-sidebar-panel="${panelId}"] { display: block; }`,
  )
  .join(" ");
---

<div class="sidebar-panel hidden" data-sidebar-panel={panelId}>
  <slot />
</div>

<style set:html={rules}></style>
