---
interface AddOnsData {
  items: string[];
}

interface Props {
  title: string;
  data: AddOnsData;
}

const { title, data } = Astro.props;
const { items } = data;
---

<div class="bg-base-100 mt-4 rounded-lg p-6 shadow">
  <h3 class="card-title mb-2 font-semibold uppercase">{title}</h3>
  {items.map((item) => <p>{item}</p>)}
</div>
